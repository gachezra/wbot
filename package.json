{
  "name": "wbot",
  "version": "0.1.0",
  "private": true,
  "description": "WhatsApp webhook listener built with NestJS",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node --watch src/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "check": "tsc --noEmit",
    "ngrok:http": "ngrok http 3000"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^24.0.0",
    "ngrok": "^5.0.0-beta.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
